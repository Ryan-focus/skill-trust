{
  "name": "skill-trust",
  "version": "0.1.0",
  "description": "Transparency verifier for Agent Skills — verify that skills declare their behavior honestly.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "skill-trust": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:action": "npm run build && ncc build dist/action/index.js -o dist/action-bundle --source-map --license licenses.txt",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent-skills",
    "ai",
    "security",
    "trust",
    "verification",
    "transparency",
    "mcp",
    "claude",
    "agent"
  ],
  "author": "Raven <ravenqiu@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ryan-focus/skill-trust"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "TRUST-SPEC.md",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
